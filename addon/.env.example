# Anthropic
ANTHROPIC_API_KEY=

# Home Assistant
HA_BASE_URL=http://supervisor/core
HA_LONG_LIVED_TOKEN=

# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Only messages from this number (E.164, no leading +, e.g. 972501234567) are accepted
ALLOWED_SENDER_NUMBER=

# Path to the entity catalog, relative to the app working directory
ENTITIES_CONFIG_PATH=config/entities.yaml

# Seconds before a pending risky-action confirmation expires
CONFIRMATION_TTL_SECONDS=120
